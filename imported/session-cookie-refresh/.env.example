# Shared
BACKEND_BASIC_USER=af_login
BACKEND_BASIC_PASSWORD=change-me
SESSION_COOKIE_NAME=AHFFI_SESSION
BACKEND_SSL_SKIP_VERIFY=true
HTTP_TIMEOUT_SECONDS=10

# Private host
PRIVATE_HOST_BIND=0.0.0.0
PRIVATE_HOST_PORT=9100
AGENT_NAME=OCI Agent Factory

# Login gateway
LOGIN_GATEWAY_BIND=0.0.0.0
LOGIN_GATEWAY_PORT=8000
